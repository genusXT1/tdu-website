rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Разрешаем чтение всем для публичных данных
    match /site/config { allow read: if true; }
    match /news/{doc} { allow read: if true; }
    match /programs/{doc} { allow read: if true; }
    match /partners/{doc} { allow read: if true; }

    // Разрешаем авторизованным пользователям создавать заявки
    match /applications/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Правила для коллекции пользователей и всего остального
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}